# Copy to .env and adjust for your environment.
# .env is git-ignored and never committed.

# PostgreSQL (retrieval_service, ingest job)
POSTGRES_URL=postgresql://rag:rag@postgres:5432/rag

# Redis (retrieval_service, inference_worker)
REDIS_URL=redis://redis:6379/0

# Retrieval service
RETRIEVAL_BUDGET_MS=40
CACHE_TTL_S=300

# Inference worker
MAX_QUEUE_SIZE=32
MAX_BATCH_SIZE=8
BATCH_TIMEOUT_MS=10
INFERENCE_LATENCY_MS=50

# Router API
HTTP_TIMEOUT_S=2.0
MAX_CONCURRENCY=64
